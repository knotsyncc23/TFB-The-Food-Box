## Backend env example (DO NOT COMMIT .env)
NODE_ENV=development
PORT=5000

## Required
MONGODB_URI=mongodb://127.0.0.1:27017/tifunbox
JWT_SECRET=change-me-to-a-strong-secret
APPLE_CLIENT_ID=com.example.service
APPLE_REDIRECT_URI=https://app.example.com/api/auth/apple/callback

## CORS (optional)
CORS_ORIGIN=http://localhost:5173

## Refresh cookie (production split frontend + API host, e.g. app.tifunbox.com → backend.tifunbox.com)
## Default: in production, SameSite=None + Secure so Safari/Chrome send the cookie on credentialed API calls.
## Set to false only if the SPA and API are same-site (e.g. reverse-proxied under one origin).
# REFRESH_COOKIE_CROSS_SITE=false
## Optional cookie Domain (e.g. .example.com) when multiple API subdomains must share the cookie.
# REFRESH_COOKIE_DOMAIN=

## Firebase Realtime Database (recommended for live tracking)
## Option A (recommended): Put your service account JSON at:
## Backend/config/serviceAccountKey.json  (this path is already gitignored)
## and set only the DB URL here:
FIREBASE_DATABASE_URL=https://tifunbox-default-rtdb.asia-southeast1.firebasedatabase.app

## Option B: Use env vars (useful for CI/hosting platforms)
## IMPORTANT: keep \n in private key and the backend will convert it to real newlines.
FIREBASE_PROJECT_ID=tifunbox
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tifunbox.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

